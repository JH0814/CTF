p = 57896044618658103051097247842201434560310253892815534401457040244646854264811
a = 57896044618658103051097247842201434560310253892815534336455328262589759096811
b = 6378745995050415640528904257536000

Gx, Gy = 46876917648549268272641716936114495226812126512396931121066067980475334056759, 29018161638760518123770904309639572979634020954930188106398864033161780615057
PAx, PAy = 41794565872898552028378254333448511042514164360566217446125286680794907163222, 28501067479064047326107608780246105661757692260405498327414296914217192089882
PBx, PBy = 832923623940209904267388169663314834051489004894067103155141367420578675552, 7382962163953851721569729505742450736497607615866914193411926051803583826592

E = EllipticCurve(GF(p), [a, b])
PB = E(PBx, PBy)

print("[!] Anomalous Curve (변칙 곡선) 확인 완료 - Smart's Attack 진행 중...")

# p-adic field로 타원곡선 정의
Eqp = EllipticCurve(Qp(p, 2), [ZZ(a), ZZ(b)])

# Hensel's Lemma를 이용해 Qp 상의 정확한 점으로 리프트 (lift_x 사용)
G_qp = Eqp.lift_x(ZZ(Gx))
# y좌표의 부호가 반대일 경우 뒤집어줌
if GF(p)(G_qp[1]) != Gy:
    G_qp = -G_qp

PA_qp = Eqp.lift_x(ZZ(PAx))
if GF(p)(PA_qp[1]) != PAy:
    PA_qp = -PA_qp

# Smart's Attack 핵심 연산
pG = p * G_qp
pPA = p * PA_qp

dx_G = pG[0] / pG[1]
dx_PA = pPA[0] / pPA[1]

# 개인키 복구
dA = ZZ(dx_PA / dx_G) % p
print(f"[+] 개인키 dA 복구 완료: {dA}")

# 공유 비밀키(Shared Secret) 연산
Secret_pt = dA * PB
secret_x = int(Secret_pt[0])

print("\n[*] 아래의 secret_x 값을 복사해서 Python 복호화 스크립트에 넣으세요:")
print(secret_x)